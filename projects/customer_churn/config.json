{
  "name": "Customer Churn Prediction System",
  "type": "ML",
  "description": "A machine learning system that predicts whether a customer is likely to leave a telecom service based on their demographics, account details, and subscribed services.",

  "problem": "Telecom companies lose revenue when customers discontinue their services. Identifying customers at risk of churning early helps businesses take preventive actions.",

  "solution": "Built a predictive model that analyzes customer demographics, subscription details, billing information, and service usage patterns to predict churn likelihood.",

  "features": [
    "Real-time churn prediction based on customer details",
    "Data preprocessing and feature engineering pipeline",
    "User-friendly interface for entering customer information",
    "Scalable backend using Flask API"
  ],

  "tags": [
    "Python",
    "Flask",
    "Scikit-learn",
    "Pandas",
    "NumPy",
    "Machine Learning",
    "Customer Analytics"
  ],

  "info": "Trained a supervised learning classification model on telecom customer data to identify churn patterns and improve customer retention strategies.",

  "future_improvements": [
    "Integrate customer support interaction history",
    "Add personalized retention recommendations",
    "Deploy as a business dashboard with analytics"
  ],

  "inputs": [
    {
      "name": "gender",
      "label": "Gender",
      "type": "select",
      "options": ["Male", "Female"],
      "required": true
    },
    {
      "name": "SeniorCitizen",
      "label": "Senior Citizen",
      "type": "radio",
      "options": [
        {"value": 1, "label": "Yes"},
        {"value": 0, "label": "No"}
      ],
      "required": true
    },
    {
      "name": "Partner",
      "label": "Has Partner",
      "type": "radio",
      "options": [
        {"value": "Yes", "label": "Yes"},
        {"value": "No", "label": "No"}
      ],
      "required": true
    },
    {
      "name": "Dependents",
      "label": "Has Dependents",
      "type": "radio",
      "options": [
        {"value": "Yes", "label": "Yes"},
        {"value": "No", "label": "No"}
      ],
      "required": true
    },
    {
      "name": "tenure",
      "label": "Tenure (Months)",
      "type": "number",
      "min": 0,
      "required": true
    },
    {
      "name": "PhoneService",
      "label": "Phone Service",
      "type": "radio",
      "options": [
        {"value": "Yes", "label": "Yes"},
        {"value": "No", "label": "No"}
      ],
      "required": true
    },
    {
      "name": "MultipleLines",
      "label": "Multiple Lines",
      "type": "select",
      "options": ["Yes", "No", "No phone service"],
      "required": true
    },
    {
      "name": "InternetService",
      "label": "Internet Service",
      "type": "select",
      "options": ["DSL", "Fiber optic", "No"],
      "required": true
    },
    {
      "name": "OnlineSecurity",
      "label": "Online Security",
      "type": "select",
      "options": ["Yes", "No", "No internet service"],
      "required": true
    },
    {
      "name": "OnlineBackup",
      "label": "Online Backup",
      "type": "select",
      "options": ["Yes", "No", "No internet service"],
      "required": true
    },
    {
      "name": "DeviceProtection",
      "label": "Device Protection",
      "type": "select",
      "options": ["Yes", "No", "No internet service"],
      "required": true
    },
    {
      "name": "TechSupport",
      "label": "Tech Support",
      "type": "select",
      "options": ["Yes", "No", "No internet service"],
      "required": true
    },
    {
      "name": "StreamingTV",
      "label": "Streaming TV",
      "type": "select",
      "options": ["Yes", "No", "No internet service"],
      "required": true
    },
    {
      "name": "StreamingMovies",
      "label": "Streaming Movies",
      "type": "select",
      "options": ["Yes", "No", "No internet service"],
      "required": true
    },
    {
      "name": "Contract",
      "label": "Contract Type",
      "type": "select",
      "options": ["Month-to-month", "One year", "Two year"],
      "required": true
    },
    {
      "name": "PaperlessBilling",
      "label": "Paperless Billing",
      "type": "radio",
      "options": [
        {"value": "Yes", "label": "Yes"},
        {"value": "No", "label": "No"}
      ],
      "required": true
    },
    {
      "name": "PaymentMethod",
      "label": "Payment Method",
      "type": "select",
      "options": [
        "Electronic check",
        "Mailed check",
        "Bank transfer (automatic)",
        "Credit card (automatic)"
      ],
      "required": true
    },
    {
      "name": "MonthlyCharges",
      "label": "Monthly Charges",
      "type": "number",
      "step": 0.01,
      "required": true
    },
    {
      "name": "TotalCharges",
      "label": "Total Charges",
      "type": "number",
      "step": 0.01,
      "required": true
    }
  ]
}